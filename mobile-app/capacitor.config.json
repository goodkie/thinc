{
  "appId": "com.thinc.lie",
  "appName": "The Truth Untold",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "*.youtube.com",
      "*.googlevideo.com",
      "*.googleapis.com",
      "inv.nadeko.net",
      "api.piped.private.coffee",
      "pipedapi.kavin.rocks",
      "piped-api.lunar.icu",
      "thinc-lie-detector-production.up.railway.app",
      "corsproxy.io",
      "corsproxy.org",
      "api.allorigins.win",
      "api.codetabs.com",
      "cors.eu.org"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "ios": {
    "contentInset": "automatic"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a1a",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a1a"
    }
  }
}